MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/expense_tracker?appName=Portfolio
MONGODB_DATABASE=expense_tracker
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION=86400000
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
SEED_DEMO_DATA=false

# Brevo API Configuration (HTTP-based, works on all hosts including Render free tier)
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key-here
MAIL_FROM=your-verified-email@gmail.com
MAIL_FROM_NAME=Expense Tracker
